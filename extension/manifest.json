{
  "manifest_version": 3,
  "name": "StudyVerse Analytics Tracker",
  "version": "1.0",
  "description": "Tracks website visits to provide distraction analytics in StudyVerse.",
  "permissions": ["tabs", "storage", "idle"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://localhost:*/*", "*://127.0.0.1:*/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
